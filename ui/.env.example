# SERVER-ONLY: Used by NextAuth to sign/encrypt JWTs and sessions.
# Required in production. Optional in development (but recommended).
AUTH_SECRET=""

# SERVER-ONLY: Controls NextAuth's trust of forwarded headers (X-Forwarded-*).
# Keep true behind proxies (Vercel, Nginx). Impacts callback URL resolution.
AUTH_TRUST_HOST=true

# SERVER-ONLY: NextAuth Discord provider credentials.
# Used only if the Discord provider is configured.
AUTH_DISCORD_ID=""
AUTH_DISCORD_SECRET=""

# SERVER-ONLY: NextAuth Auth0 provider credentials.
# AUTH_AUTH0_ISSUER must be a URL (e.g., https://YOUR_TENANT.eu.auth0.com/).
AUTH_AUTH0_ID=""
AUTH_AUTH0_SECRET=""
AUTH_AUTH0_ISSUER=""

# SERVER-ONLY: Vercel project domain (optional).
# Sometimes used by auth callbacks or canonical URL building.
VERCEL_DOMAIN=""

# SERVER-ONLY: Port the Next.js server listens on locally.
# Parsed as a number; if blank, defaults to 3000.
PORT=""

# BOTH: Build/runtime mode for Next.js and libraries.
# Accepted: development | test | production
NODE_ENV="development"

# SERVER-ONLY: Base URL of your backend API.
# Must be a valid URL. Is mirrored to NEXT_PUBLIC_API_URL for the client.
API_URL="http://localhost:3000"

# SERVER-ONLY: Public site root used for external/legal page redirects.
# Must be a valid URL. Is mirrored to NEXT_PUBLIC_WEBFLOW_SITE for the client.
WEBFLOW_SITE=""

# CLIENT-ONLY: Mirrors NODE_ENV to the browser.
# Used for client-side feature flags/behaviors consistent with server NODE_ENV.
NEXT_PUBLIC_NODE_ENV="${NODE_ENV}"

# CLIENT-ONLY: Mirrors API_URL to the browser.
# Used by the frontend to call the backend directly (if not proxying).
NEXT_PUBLIC_API_URL="${API_URL}"

# CLIENT-ONLY: Toggles whether the client should call the API via a proxy route.
# true => use NEXT_PUBLIC_API_PROXY_PREFIX; false => use NEXT_PUBLIC_API_URL.
NEXT_PUBLIC_USE_API_PROXY=true

# CLIENT-ONLY: Where the client should send proxied API requests when proxying is enabled.
# Must be a URL. Default during dev is http://localhost:3000/api/proxy.
NEXT_PUBLIC_API_PROXY_PREFIX=http://localhost:3000/api/proxy

# CLIENT-ONLY: Sets the referrer policy for fetch/navigation (e.g., in fetch helpers).
# Defaults to 'no-referrer' if not provided.
NEXT_PUBLIC_REFERRER_POLICY='no-referrer'

# CLIENT-ONLY: Mirrors WEBFLOW_SITE to the browser.
# Used by client-side redirects to public/legal pages (e.g., /privacy-policy).
NEXT_PUBLIC_WEBFLOW_SITE="${WEBFLOW_SITE}"
