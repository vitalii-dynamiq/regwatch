{
  "name": "reg-watch-web",
  "version": "0.5.12",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build",
    "check": "biome check .",
    "check:unsafe": "biome check --write --unsafe .",
    "check:write": "biome check --write .",
    "commit:check": "commitlint --edit .git/COMMIT_EDITMSG",
    "deploy:prod": "vercel pull --environment=production && vercel build --prod && vercel deploy --prebuilt --prod",
    "dev": "next dev --turbo",
    "find:unused:components": "node scripts/find-unused-components.mjs",
    "format:write": "biome format --write .",
    "postrelease": "conventional-changelog -i CHANGELOG.md -s -r 0 -n changelog.config.cjs",
    "prepare": "husky",
    "preview": "next build && next start",
    "release": "standard-version --skip.changelog && pnpm run postrelease",
    "release:major": "standard-version --skip.changelog --release-as major && pnpm run postrelease",
    "release:minor": "standard-version --skip.changelog --release-as minor && pnpm run postrelease",
    "release:patch": "standard-version --skip.changelog --release-as patch && pnpm run postrelease",
    "start": "next start",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.1",
    "@radix-ui/react-alert-dialog": "^1.1.14",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.7",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@t3-oss/env-nextjs": "^0.12.0",
    "@tabler/icons-react": "^3.34.1",
    "@tanstack/react-query": "^5.69.0",
    "@tanstack/react-query-devtools": "^5.84.1",
    "@tanstack/react-table": "^8.21.3",
    "@trpc/client": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.23.12",
    "html-react-parser": "^5.2.6",
    "lucide-react": "^0.536.0",
    "next": "^15.5.14",
    "next-auth": "5.0.0-beta.25",
    "next-themes": "^0.4.6",
    "react": "^19.1.2",
    "react-day-picker": "^9.8.1",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.62.0",
    "recharts": "^2.15.4",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "superjson": "^2.2.1",
    "tailwind-merge": "^3.3.1",
    "zod": "^3.24.2",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@faker-js/faker": "^9.9.0",
    "@tailwindcss/postcss": "^4.0.15",
    "@types/node": "^20.14.10",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "commitlint-plugin-function-rules": "^4.0.2",
    "conventional-changelog-cli": "^5.0.0",
    "husky": "^9.1.7",
    "postcss": "^8.5.3",
    "standard-version": "^9.5.0",
    "tailwindcss": "^4.0.15",
    "tw-animate-css": "^1.3.6",
    "typescript": "^5.8.2",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "react-is": "^19.1.2"
  },
  "ct3aMetadata": {
    "initVersion": "7.39.3"
  },
  "packageManager": "pnpm@10.24.0"
}
