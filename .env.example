# =============================================================================
# RegWatch — Environment Variables
# =============================================================================
# Copy to .env and fill in values marked <REQUIRED>.
#
# LOCAL DEV:  Used by root docker-compose.yaml. DB/Redis URLs are pre-wired.
# RAILWAY:    Comments marked "RAILWAY:" show the value to set in Railway dashboard.
#             ${{service.VAR}} is Railway's variable reference syntax.
# =============================================================================

# =============================================================================
# SHARED — Auth0 (used by both API and UI)
# =============================================================================
AUTH0_DOMAIN=<REQUIRED>
AUTH0_API_AUDIENCE=<REQUIRED>
AUTH0_ALGORITHMS=RS256
AUTH0_ISSUER=<REQUIRED>

# =============================================================================
# API SERVICE
# =============================================================================

# --- Core ---
ENV=local
# RAILWAY: prod

DEBUG=true
# RAILWAY: false

SERVER_HOST=0.0.0.0
SERVER_PORT=8080
# RAILWAY: ${{PORT}}

SERVER_TIMEOUT_KEEP_ALIVE=120
SERVER_WORKERS=1

# --- Database ---
# Local: pre-wired to docker-compose db service
DB_URL=postgresql+asyncpg://postgres:postgres@db:5432/regwatch
# RAILWAY: postgresql+asyncpg://${{postgres.PGUSER}}:${{postgres.PGPASSWORD}}@${{postgres.RAILWAY_PRIVATE_DOMAIN}}:${{postgres.PGPORT}}/${{postgres.PGDATABASE}}

DB_POOL_MAX_SIZE=5
DB_POOL_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=600

# --- Redis ---
REDIS_ENABLED=true
REDIS_URL=redis://redis:6379/0
# RAILWAY: ${{redis.REDIS_URL}}

# --- Taskiq ---
TASKIQ_ENABLED=true
TASKIQ_WORKERS=2
TASKIQ_MAX_ASYNC_TASKS=20
TASKIQ_ADMIN_URL=
TASKIQ_ADMIN_API_TOKEN=local-dev-token

# --- API Keys ---
JINA_API_KEY=<REQUIRED>
TOGETHER_API_KEY=<REQUIRED>

# --- Admin ---
ADMIN_TOKEN=local-admin-token
# RAILWAY: <generate a strong random token>

# --- CORS ---
# CORS_ORIGINS=["*"]
# RAILWAY: ["https://<ui-domain>.up.railway.app"]

# --- Sentry (optional) ---
SENTRY_DSN=

# =============================================================================
# UI SERVICE
# =============================================================================

# --- NextAuth ---
AUTH_SECRET=local-dev-secret-change-me-in-prod!!
# RAILWAY: <generate with: openssl rand -base64 32>

AUTH_TRUST_HOST=true

# --- Auth0 Provider (NextAuth) ---
AUTH_AUTH0_ID=<REQUIRED>
AUTH_AUTH0_SECRET=<REQUIRED>
AUTH_AUTH0_ISSUER=<REQUIRED>
# e.g. https://your-tenant.eu.auth0.com/

# --- API Connection ---
# Server-side: how the UI server reaches the API (internal network)
API_URL=http://api:8080
# RAILWAY: http://${{api.RAILWAY_PRIVATE_DOMAIN}}:8080

# Client-side: browser calls go through the UI proxy
NEXT_PUBLIC_API_URL=http://localhost:3000
# RAILWAY: https://<ui-domain>.up.railway.app

NEXT_PUBLIC_USE_API_PROXY=true
NEXT_PUBLIC_API_PROXY_PREFIX=http://localhost:3000/api/proxy
# RAILWAY: https://<ui-domain>.up.railway.app/api/proxy

# --- Misc ---
NODE_ENV=development
# RAILWAY: production

NEXT_PUBLIC_NODE_ENV=development
# RAILWAY: production

NEXT_PUBLIC_REFERRER_POLICY=no-referrer

WEBFLOW_SITE=https://example.com
NEXT_PUBLIC_WEBFLOW_SITE=https://example.com
# RAILWAY: <your actual Webflow site URL>

# =============================================================================
# RAILWAY SETUP INSTRUCTIONS
# =============================================================================
#
# 1. Create a new project at railway.app and connect your GitHub repo.
#
# 2. Add managed databases:
#    - PostgreSQL (plugin) → auto-provisions PGUSER, PGPASSWORD, etc.
#    - Redis (plugin)      → auto-provisions REDIS_URL
#
# 3. Add services (set "Root Directory" for each):
#
#    SERVICE          ROOT DIR    START COMMAND
#    ───────────────  ──────────  ─────────────────────────────────────────────
#    api              api/        alembic upgrade head && python server.py
#    ui               ui/         (default from Dockerfile)
#    taskiq-worker    api/        taskiq worker app.taskiq.broker:broker --workers 2 --max-async-tasks 20
#    taskiq-scheduler api/        taskiq scheduler app.taskiq.schedulers.cron:scheduler
#
# 4. Set environment variables per service using the RAILWAY: values above.
#    Use ${{service.VAR}} syntax to reference other services' variables.
#
# 5. Generate a public domain for api and ui services (Settings → Networking).
#
# 6. Update Auth0 dashboard:
#    - Allowed Callback URLs:  https://<ui-domain>.up.railway.app/api/auth/callback/auth0
#    - Allowed Logout URLs:    https://<ui-domain>.up.railway.app
#    - Allowed Web Origins:    https://<ui-domain>.up.railway.app
#
# 7. Push to main → Railway auto-deploys all services.
# =============================================================================
